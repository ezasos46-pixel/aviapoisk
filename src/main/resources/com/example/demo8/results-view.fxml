<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo8.controllers.ResultsController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: #0b1628;">

    <!-- ШАПКА -->
    <top>
        <VBox style="-fx-background-color: #080f1e; -fx-border-color: rgba(79,195,247,0.12); -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 32; -fx-min-height: 60;">
                <Button text="&lt;- Назад" onAction="#handleBack"
                        style="-fx-background-color: transparent; -fx-text-fill: #4fc3f7; -fx-font-size: 13px; -fx-padding: 8 16; -fx-border-color: rgba(79,195,247,0.3); -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Label fx:id="routeLabel" text="Результаты поиска"
                       style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="countLabel" text=""
                       style="-fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 13px;"/>
            </HBox>
            <!-- Панель сортировки и фильтров -->
            <HBox spacing="16" alignment="CENTER_LEFT"
                  style="-fx-padding: 10 32; -fx-background-color: #0d1b3e; -fx-border-color: rgba(79,195,247,0.08); -fx-border-width: 1 0 0 0;">
                <Label text="Сортировка:" style="-fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px;"/>
                <Button fx:id="sortPriceBtn" text="По цене" onAction="#handleSortPrice"
                        style="-fx-background-color: rgba(79,195,247,0.2); -fx-text-fill: #4fc3f7; -fx-font-size: 12px; -fx-padding: 5 14; -fx-background-radius: 20; -fx-border-color: #4fc3f7; -fx-border-width: 1; -fx-border-radius: 20; -fx-cursor: hand;"/>
                <Button fx:id="sortTimeBtn" text="По времени вылета" onAction="#handleSortTime"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px; -fx-padding: 5 14; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 1; -fx-border-radius: 20; -fx-cursor: hand;"/>
                <Button fx:id="sortDurBtn" text="По длительности" onAction="#handleSortDuration"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px; -fx-padding: 5 14; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 1; -fx-border-radius: 20; -fx-cursor: hand;"/>
                <Separator orientation="VERTICAL" style="-fx-padding: 0 4;"/>
                <Label text="Время вылета:" style="-fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px;"/>
                <Button fx:id="filterMorningBtn" text="Утро 6-12" onAction="#handleFilterMorning"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px; -fx-padding: 5 14; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 1; -fx-border-radius: 20; -fx-cursor: hand;"/>
                <Button fx:id="filterDayBtn" text="День 12-18" onAction="#handleFilterDay"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px; -fx-padding: 5 14; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 1; -fx-border-radius: 20; -fx-cursor: hand;"/>
                <Button fx:id="filterEveningBtn" text="Вечер 18-24" onAction="#handleFilterEvening"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px; -fx-padding: 5 14; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 1; -fx-border-radius: 20; -fx-cursor: hand;"/>
                <Button fx:id="filterAllBtn" text="Все" onAction="#handleFilterAll"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px; -fx-padding: 5 14; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.15); -fx-border-width: 1; -fx-border-radius: 20; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ЦЕНТР -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox fx:id="flightsContainer" spacing="10"
                  style="-fx-padding: 20 40; -fx-background-color: #0b1628;">
                <Label fx:id="noResultsLabel" text="Загрузка рейсов..."
                       style="-fx-text-fill: rgba(180,200,255,0.7); -fx-font-size: 16px;" visible="true"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
