<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo8.controllers.MainController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: #0b1628;">

    <!-- ===== ШАПКА ===== -->
    <top>
        <HBox fx:id="mainHeaderHBox" alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: rgba(13,27,62,0.95); -fx-padding: 0 32; -fx-min-height: 64; -fx-border-color: rgba(79,195,247,0.12); -fx-border-width: 0 0 1 0;">

            <!-- Логотип -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="✈" style="-fx-text-fill: #4fc3f7; -fx-font-size: 26px;"/>
                <VBox spacing="-4" alignment="CENTER_LEFT">
                    <Label text="АвиаПоиск" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label text="Билеты по России" style="-fx-text-fill: rgba(79,195,247,0.7); -fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Навигация -->
            <HBox alignment="CENTER" spacing="8">
                <Button fx:id="themeToggleButton" text="🌙"
                        style="-fx-background-color: transparent; -fx-text-fill: #4fc3f7; -fx-font-size: 18px; -fx-padding: 6 10; -fx-cursor: hand; -fx-border-color: rgba(79,195,247,0.35); -fx-border-width: 1; -fx-background-radius: 6;"
                        onAction="#handleThemeToggle"/>
                <Button fx:id="authButton" text="Войти"
                        style="-fx-background-color: transparent; -fx-text-fill: #4fc3f7; -fx-font-size: 13px; -fx-padding: 8 20; -fx-border-color: #4fc3f7; -fx-border-width: 1.5; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;"
                        onAction="#handleAuth"/>
                <Button fx:id="profileButton" text="Профиль"
                        style="-fx-background-color: #4fc3f7; -fx-text-fill: #0b1628; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"
                        onAction="#handleProfile"/>
            </HBox>
        </HBox>
    </top>

    <!-- ===== ЦЕНТР ===== -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox fx:id="mainScrollVBox" spacing="0" style="-fx-background-color: #0b1628;">

                <!-- HERO секция -->
                <VBox fx:id="mainHeroVBox" alignment="CENTER" spacing="24"
                      style="-fx-padding: 60 80 50 80; -fx-background-color: linear-gradient(to bottom, #0d1b3e, #0b1628);">

                    <VBox alignment="CENTER" spacing="8">
                        <Label fx:id="heroTitleLabel" text="Найдите лучшие авиабилеты"
                               style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;"/>
                        <Label fx:id="heroSubtitleLabel" text="Поиск по всем направлениям России — быстро и удобно"
                               style="-fx-text-fill: rgba(180,200,255,0.7); -fx-font-size: 15px;"/>
                    </VBox>

                    <!-- Поисковая карточка -->
                    <VBox fx:id="mainSearchCard" spacing="0"
                          style="-fx-background-color: #131f3e; -fx-background-radius: 16; -fx-border-color: rgba(79,195,247,0.18); -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 30, 0, 0, 10);"
                          maxWidth="1000">

                        <!-- Строка городов и дат -->
                        <HBox spacing="0" alignment="CENTER_LEFT"
                              style="-fx-padding: 0; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">

                            <!-- Откуда -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-padding: 18 20; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 1 0 0;">
                                <Label text="ОТКУДА" style="-fx-text-fill: #4fc3f7; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <ComboBox fx:id="fromCityCombo" maxWidth="Infinity" promptText="Город вылета"
                                          style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 15px; -fx-padding: 0;"/>
                            </VBox>

                            <!-- Стрелка -->
                            <Label text="⇄" style="-fx-text-fill: rgba(79,195,247,0.5); -fx-font-size: 18px; -fx-padding: 0 4;"/>

                            <!-- Куда -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-padding: 18 20; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 1 0 0;">
                                <Label text="КУДА" style="-fx-text-fill: #4fc3f7; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <ComboBox fx:id="toCityCombo" maxWidth="Infinity" promptText="Город прилёта"
                                          style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 15px; -fx-padding: 0;"/>
                            </VBox>

                            <!-- Пересадка -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-padding: 18 20; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 1 0 0;">
                                <Label text="ПЕРЕСАДКА" style="-fx-text-fill: rgba(79,195,247,0.6); -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <ComboBox fx:id="stopCityCombo" maxWidth="Infinity" promptText="Необязательно"
                                          style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 15px; -fx-padding: 0;"/>
                            </VBox>

                            <!-- Дата туда -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-padding: 18 20; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 1 0 0;">
                                <Label text="ДАТА ВЫЛЕТА" style="-fx-text-fill: #4fc3f7; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <DatePicker fx:id="departureDatePicker" maxWidth="Infinity"
                                            style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 15px;"/>
                            </VBox>

                            <!-- Дата обратно -->
                            <VBox spacing="4" HBox.hgrow="ALWAYS"
                                  style="-fx-padding: 18 20;">
                                <Label text="ОБРАТНО" style="-fx-text-fill: rgba(79,195,247,0.6); -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <DatePicker fx:id="returnDatePicker" maxWidth="Infinity"
                                            style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 15px;"/>
                            </VBox>
                        </HBox>

                        <!-- Строка пассажиров и кнопок -->
                        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 16 20;">
                            <Button fx:id="passengersButton" text="1 пассажир · Эконом"
                                    style="-fx-background-color: rgba(79,195,247,0.1); -fx-text-fill: #c8e6ff; -fx-font-size: 13px; -fx-padding: 9 16; -fx-background-radius: 8; -fx-border-color: rgba(79,195,247,0.25); -fx-border-width: 1; -fx-border-radius: 8; -fx-cursor: hand;"
                                    onAction="#handlePassengers"/>
                            <CheckBox fx:id="extraBaggageCheck" text="+ Доп. багаж"
                                      style="-fx-font-size: 13px; -fx-text-fill: #c8e6ff;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnShortestPath" text="Кратчайший маршрут"
                                    style="-fx-background-color: rgba(0,150,136,0.2); -fx-text-fill: #4db6ac; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-border-color: rgba(0,150,136,0.4); -fx-border-width: 1; -fx-border-radius: 8; -fx-cursor: hand;"
                                    onAction="#handleShortestPath"/>
                            <Button fx:id="btnFindTickets" text="  Найти билеты  "
                                    style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 10 32; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(229,57,53,0.4), 12, 0, 0, 4); -fx-cursor: hand;"
                                    onAction="#handleSearch"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- ГОРОДА -->
                <VBox fx:id="mainCitiesSection" spacing="16" alignment="CENTER" style="-fx-padding: 40 80 30 80; -fx-background-color: #0b1628;">
                    <Label fx:id="citiesTitleLabel" text="Топ 4 города для посещения" alignment="CENTER" maxWidth="Infinity"
                           style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-alignment: center;"/>
                    <Label fx:id="citiesHintLabel" text="Нажмите на город, чтобы узнать подробнее"
                           style="-fx-text-fill: rgba(180,200,255,0.5); -fx-font-size: 12px;"/>
                    <HBox fx:id="citiesBox" alignment="CENTER" spacing="10" style="-fx-padding: 2 0 8 0;"/>
                </VBox>

                <!-- ПРЕИМУЩЕСТВА -->
                <HBox fx:id="mainFeaturesRow" spacing="12" style="-fx-padding: 24 80 50 80; -fx-background-color: #0b1628;">
                    <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(79,195,247,0.05); -fx-background-radius: 10; -fx-padding: 18; -fx-border-color: rgba(79,195,247,0.08); -fx-border-width: 1; -fx-border-radius: 10;">
                        <Label text="⚡  Быстрый поиск" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Результаты за секунды по всем рейсам" style="-fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px;" wrapText="true"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(79,195,247,0.05); -fx-background-radius: 10; -fx-padding: 18; -fx-border-color: rgba(79,195,247,0.08); -fx-border-width: 1; -fx-border-radius: 10;">
                        <Label text="📍  Кратчайший маршрут" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Алгоритм Дейкстры найдёт самый дешёвый путь" style="-fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px;" wrapText="true"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(79,195,247,0.05); -fx-background-radius: 10; -fx-padding: 18; -fx-border-color: rgba(79,195,247,0.08); -fx-border-width: 1; -fx-border-radius: 10;">
                        <Label text="✈  Рейсы с пересадкой" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Ищите маршруты А → Б → С с удобной пересадкой" style="-fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px;" wrapText="true"/>
                    </VBox>
                    <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT"
                          style="-fx-background-color: rgba(79,195,247,0.05); -fx-background-radius: 10; -fx-padding: 18; -fx-border-color: rgba(79,195,247,0.08); -fx-border-width: 1; -fx-border-radius: 10;">
                        <Label text="🔒  Безопасное бронирование" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label text="Ваши данные защищены, оплата надёжна" style="-fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 12px;" wrapText="true"/>
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- ===== ПОДВАЛ ===== -->
    <bottom>
        <HBox fx:id="mainFooterHBox" alignment="CENTER" spacing="20"
              style="-fx-background-color: #080f1e; -fx-padding: 14 32; -fx-border-color: rgba(79,195,247,0.08); -fx-border-width: 1 0 0 0;">
            <Label text="© 2026 АвиаПоиск" style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Правила поведения на борту"
                    style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 12px; -fx-border-color: transparent; -fx-cursor: hand; -fx-underline: true; -fx-padding: 4 0;"
                    onAction="#openRules"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Все рейсы по России" style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 12px;"/>
        </HBox>
    </bottom>
</BorderPane>
