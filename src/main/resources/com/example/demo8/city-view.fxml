<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo8.controllers.CityController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #0b1628;">

    <!-- ШАПКА -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #0d1b3e; -fx-padding: 16 24; -fx-border-color: rgba(79,195,247,0.12); -fx-border-width: 0 0 1 0;">
            <Button text="← Назад" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: #4fc3f7; -fx-font-size: 13px; -fx-border-color: rgba(79,195,247,0.4); -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;"/>
            <Label fx:id="titleLabel" text=""
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="codeLabel" text=""
                   style="-fx-text-fill: #4fc3f7; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: rgba(79,195,247,0.12); -fx-background-radius: 6; -fx-padding: 4 10;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox spacing="0" style="-fx-background-color: #0b1628;">

                <!-- HERO баннер -->
                <VBox fx:id="heroBanner" alignment="CENTER" spacing="10"
                      style="-fx-padding: 50 40 40 40; -fx-background-color: linear-gradient(to bottom right, #0d1b3e, #131f3e);">
                    <Label fx:id="heroEmoji" text="✈" style="-fx-font-size: 64px;"/>
                    <Label fx:id="heroName" text="" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    <Label fx:id="heroCountry" text="" style="-fx-text-fill: rgba(180,200,255,0.6); -fx-font-size: 14px;"/>
                    <Label fx:id="heroDesc" text="" style="-fx-text-fill: rgba(200,220,255,0.8); -fx-font-size: 13px; -fx-wrap-text: true; -fx-text-alignment: center;" maxWidth="600"/>
                </VBox>

                <!-- ФАКТЫ -->
                <HBox fx:id="factsBox" spacing="12"
                      style="-fx-padding: 24 40; -fx-background-color: #0b1628;"/>

                <!-- ДОСТОПРИМЕЧАТЕЛЬНОСТИ -->
                <VBox spacing="14" style="-fx-padding: 0 40 16 40;">
                    <Label text="Достопримечательности"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <VBox fx:id="attractionsBox" spacing="10"/>
                </VBox>

                <!-- СОВЕТЫ -->
                <VBox spacing="14" style="-fx-padding: 0 40 32 40;">
                    <Label text="Советы путешественнику"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <VBox fx:id="tipsBox" spacing="8"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- КНОПКА ПОИСКА -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #080f1e; -fx-padding: 16 24; -fx-border-color: rgba(79,195,247,0.08); -fx-border-width: 1 0 0 0;">
            <Button fx:id="searchBtn" text="✈  Найти билеты в этот город" onAction="#handleSearchFlights"
                    style="-fx-background-color: #e53935; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 12 40; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(229,57,53,0.4), 12, 0, 0, 4);"/>
        </HBox>
    </bottom>
</BorderPane>
